<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #101930;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="UI.PreferencesController">

    <top>
        <VBox style="-fx-padding: 20 0 10 0; -fx-alignment: center;">
            <Label text="Preferences" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
        </VBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 30; -fx-alignment: top-center;">

            <!-- Background Theme -->
            <VBox spacing="8">
                <Label text="Background Theme" style="-fx-text-fill: #a0b0cc; -fx-font-size: 13px; -fx-font-weight: bold;" />
                <ComboBox fx:id="backgroundThemeCombo" prefWidth="300"
                          style="-fx-background-color: #1e2d4a; -fx-text-fill: white; -fx-border-color: #2e4070; -fx-border-radius: 4;" />
            </VBox>

            <Separator style="-fx-background-color: #2e4070;" />

            <!-- Piece Theme -->
            <VBox spacing="8">
                <Label text="Piece Theme" style="-fx-text-fill: #a0b0cc; -fx-font-size: 13px; -fx-font-weight: bold;" />
                <ComboBox fx:id="pieceThemeCombo" prefWidth="300"
                          style="-fx-background-color: #1e2d4a; -fx-text-fill: white; -fx-border-color: #2e4070; -fx-border-radius: 4;" />
            </VBox>

            <Separator style="-fx-background-color: #2e4070;" />

            <!-- Undos Per Click -->
            <VBox spacing="8">
                <Label text="Undos Per Click" style="-fx-text-fill: #a0b0cc; -fx-font-size: 13px; -fx-font-weight: bold;" />
                <Spinner fx:id="undosSpinner" min="1" max="10" initialValue="1" prefWidth="300"
                         style="-fx-background-color: #1e2d4a; -fx-text-fill: white; -fx-border-color: #2e4070; -fx-border-radius: 4;" />
            </VBox>

        </VBox>
    </center>

    <bottom>
        <HBox spacing="15" style="-fx-padding: 20; -fx-alignment: center-right;">
            <Button text="Cancel" onAction="#handleCancel"
                    style="-fx-background-color: #1e2d4a; -fx-text-fill: white; -fx-border-color: #2e4070; -fx-border-radius: 4; -fx-padding: 8 20; -fx-cursor: hand;" />
            <Button text="Save" onAction="#handleSave"
                    style="-fx-background-color: #2e5aac; -fx-text-fill: white; -fx-border-radius: 4; -fx-padding: 8 20; -fx-cursor: hand;" />
        </HBox>
    </bottom>

</BorderPane>