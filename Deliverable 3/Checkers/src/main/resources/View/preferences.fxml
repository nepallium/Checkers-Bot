<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" style="-fx-background-color: #1a2540; -fx-padding: 24;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="UI.PreferencesController">
    <children>
        
        <Label text="Piece Style" style="-fx-text-fill: #aab4cc; -fx-font-size: 11px; -fx-font-weight: bold;" />
        <HBox spacing="16.0">
            <children>
                <RadioButton fx:id="pieceDogRadio" text="Dog" style="-fx-text-fill: white;">
                    <toggleGroup>
                        <ToggleGroup fx:id="pieceToggleGroup" />
                    </toggleGroup>
                </RadioButton>
                <RadioButton fx:id="pieceDefaultRadio" text="Default (Colors)" style="-fx-text-fill: white;" toggleGroup="$pieceToggleGroup" />
            </children>
        </HBox>

        <Separator style="-fx-background-color: #2e3f6e;" />

        <Label text="Board Color Theme" style="-fx-text-fill: #aab4cc; -fx-font-size: 11px; -fx-font-weight: bold;" />
        <HBox spacing="16.0">
            <children>
                <RadioButton fx:id="boardBlueRadio" text="Blue &amp; White" style="-fx-text-fill: white;">
                    <toggleGroup>
                        <ToggleGroup fx:id="boardToggleGroup" />
                    </toggleGroup>
                </RadioButton>
                <RadioButton fx:id="boardBrownRadio" text="Brown &amp; White" style="-fx-text-fill: white;" toggleGroup="$boardToggleGroup" />
            </children>
        </HBox>

        <Separator style="-fx-background-color: #2e3f6e;" />

        <Label text="Move Indicator" style="-fx-text-fill: #aab4cc; -fx-font-size: 11px; -fx-font-weight: bold;" />
        <HBox spacing="16.0">
            <children>
                <RadioButton fx:id="targetCircleRadio" text="Target (circle)" style="-fx-text-fill: white;">
                    <toggleGroup>
                        <ToggleGroup fx:id="targetToggleGroup" />
                    </toggleGroup>
                </RadioButton>
                <RadioButton fx:id="targetXRadio" text="X" style="-fx-text-fill: white;" toggleGroup="$targetToggleGroup" />
            </children>
        </HBox>

        <Separator style="-fx-background-color: #2e3f6e;" />

        <HBox spacing="12.0" alignment="CENTER_RIGHT">
            <children>
                <Button text="Cancel" onAction="#onCancelClicked"
                        style="-fx-background-color: #2e3f6e; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 4;" />
                <Button text="Apply" onAction="#onApplyClicked"
                        style="-fx-background-color: #4a6fa5; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 4;" />
            </children>
        </HBox>

    </children>
</VBox>
